# --- Server ---
PORT=3001
STATE_FILE=./data/constructos.json

# --- Database (optional — not yet wired up; app runs on STATE_FILE by default) ---
DATABASE_URL=

# --- Arc Testnet / Blockchain Settlement ---
# Set ARC_MODE=real for genuine on-chain settlement and deposit verification.
# Leave unset or set to "mock" to run entirely offline with simulated receipts
# (useful for UI development without a funded wallet).
ARC_MODE=mock

ARC_RPC_URL=https://rpc.testnet.arc.network
ARC_CHAIN_ID=5042002
ARC_USDC_ADDRESS=0x3600000000000000000000000000000000000000

# Required when ARC_MODE=real. The treasury wallet's private key — this
# wallet both receives deposits and pays out settlements. Treat this like
# any other private key: never commit it, never share it, rotate it if it's
# ever exposed.
TREASURY_PRIVATE_KEY=

# Optional: override the treasury's public address explicitly (otherwise
# it's derived automatically from TREASURY_PRIVATE_KEY). Useful if you want
# deposit verification to work without giving this process signing
# capability.
ARC_TREASURY_ADDRESS=

# Optional: settlement transfer method. "native" (default) is a plain USDC
# value transfer, cheaper (~21k gas). "erc20" uses the USDC contract's
# transfer() call instead (~65k gas) — only needed if a recipient requires
# ERC-20 Transfer event semantics specifically.
ARC_TRANSFER_MODE=native
