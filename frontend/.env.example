# Must match your backend's treasury wallet address (either the address
# derived from TREASURY_PRIVATE_KEY, or ARC_TREASURY_ADDRESS if you set
# that explicitly). This is public information — safe to expose in the
# frontend, unlike the private key itself.
VITE_TREASURY_ADDRESS=

VITE_ARC_USDC_ADDRESS=0x3600000000000000000000000000000000000000

# Optional: enables the WalletConnect option in the connect-wallet modal.
# Get a free Project ID at https://cloud.walletconnect.com — without one,
# only MetaMask/injected wallet connection is available (which is enough
# for most demo purposes).
VITE_WALLETCONNECT_PROJECT_ID=
