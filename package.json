{
  "name": "constructos",
  "version": "0.4.0",
  "description": "Construction Finance Economic Layer (CFEL)",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx src/server.ts",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:all": "npm run dev & cd frontend && npm run dev",
    "build": "tsc -p .",
    "build:frontend": "cd frontend && npm run build",
    "build:all": "npm run build && cd frontend && npm run build",
    "test": "tsx --test test/*.test.ts",
    "typecheck": "tsc --noEmit",
    "typecheck:frontend": "cd frontend && npx tsc --noEmit",
    "typecheck:all": "tsc --noEmit && cd frontend && npx tsc --noEmit",
    "clean": "rm -rf dist node_modules/.cache && cd frontend && rm -rf dist",
    "reset-demo": "tsx scripts/reset-demo.ts"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "pg": "^8.12.0",
    "viem": "^2.21.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0"
  }
}
